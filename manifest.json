{
    "manifest_version": 3,
    "name": "PineFetch Link Dump",
    "version": "0.1.0",
    "description": "Export YouTube links from the current tab or send them to a local PineFetch instance.",
    "icons": {
        "16": "assets/images/logo.png",
        "32": "assets/images/logo.png",
        "48": "assets/images/logo.png",
        "128": "assets/images/logo.png"
    },
    "permissions": ["activeTab", "scripting", "downloads", "storage"],
    "host_permissions": ["<all_urls>"],
    "action": {
        "default_title": "PineFetch Link Dump",
        "default_popup": "popup.html",
        "default_icon": {
            "16": "assets/images/logo.png",
            "32": "assets/images/logo.png",
            "48": "assets/images/logo.png",
            "128": "assets/images/logo.png"
        }
    }
}
